<%= form_with(model: todo, class: "contents") do |form| %>
  <div class="my-5">
    <%= form.text_field :name,
    class: [
      "block shadow-sm rounded-md border px-3 py-2 mt-2 w-full",
      {
        "border-gray-400 focus:outline-blue-600" => todo.errors[:name].none?,
        "border-red-400 focus:outline-red-600" => todo.errors[:name].any?
      }
    ] %>
  </div>
<% end %>
