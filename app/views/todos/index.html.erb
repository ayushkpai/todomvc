<div class="w-full">
  <h1 class="text-center text-4xl text-pink-600">Todos</h1>
  <div>
    <%= render "todos/form", todo: @todo %>
  </div>

  <div class="flex justify-center mt-5">
    <div class="bg-linear-to-r from-pink-300 to-blue-300 text-black w-120 p-3 rounded">
      <div id="todos" class="min-w-full space-y-5 mx-2">
        <% if @todos.any? %>
          <% @todos.each do |todo| %>
            <div class="flex flex-col sm:flex-row justify-between items-center pb-5 border-b border-white/40">
              <div class="w-full">
                <div id="show-<%= todo.id %>">
                  <div class="flex items-center gap-2">
                    <% if todo.completed %>
                      <span class="text-green-600 text-xl">✔</span>
                    <% end %>

                    <div class="<%= 'line-through text-gray-600' if todo.completed %>">
                      <%= render todo %>
                    </div>
                  </div>
                </div>

                <div id="edit-<%= todo.id %>" class="hidden mt-2">
                  <%= render "todos/form", todo: todo %>
                </div>
              </div>

              <div class="w-full sm:w-auto flex flex-col sm:flex-row gap-2 mt-3 sm:mt-0">
                <%= button_to(todo.completed ? "↩ Undo" : "✓ Done", toggle_todo_path(todo), method: :patch, class: "w-full sm:w-auto bg-green-500 hover:bg-green-600 text-white rounded-md px-3 py-2") %>
                <button type="button" onclick="toggleEdit(<%= todo.id %>)" class="w-full sm:w-auto bg-yellow-400 hover:bg-yellow-500 rounded-md px-3 py-2">✏️ Edit</button>
                <%= button_to("🗑 Delete", todo, method: :delete, class: "w-full sm:w-auto bg-red-500 hover:bg-red-600 text-white rounded-md px-3 py-2", data: { turbo_confirm: "Are you sure" }) %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-center my-10">No todos found.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleEdit(id) {
    document.getElementById("show-" + id).classList.toggle("hidden");
    document.getElementById("edit-" + id).classList.toggle("hidden");
  }
</script>
