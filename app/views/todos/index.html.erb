<div class="w-full">
  <h1 class="text-center text-4xl text-pink-600">Todos</h1>
  <div>
    <%= render "todos/form", todo: @todo %>
  </div>

  <div class="flex justify-center mt-5">
    <div class="bg-linear-to-r from-pink-300 to-blue-300 text-black w-120 p-3 rounded">
      <div id="todos" class="min-w-full space-y-5 mx-2">
        <% if @todos.any? %>
          <% @todos.each do |todo| %>
            <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
              <div class="w-full">
                <div id="show-<%= todo.id %>">
                  <%= render todo %>
                </div>
                <div id="edit-<%= todo.id %>" class="hidden mt-2">
                  <%= render "todos/form", todo: todo %>
                </div>
              </div>
              <div class="w-full sm:w-auto flex flex-col sm:flex-row gap-2">
                <button type="button" onclick="toggleEdit(<%= todo.id %>)" class="w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 inline-block font-medium">✏️</button>
                <%= button_to "X", todo, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-red-600 hover:text-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-center my-10">No todos found.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleEdit(id) {
    document.getElementById("show-" + id).classList.toggle("hidden");
    document.getElementById("edit-" + id).classList.toggle("hidden");
  }
</script>
