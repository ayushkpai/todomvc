<% content_for :title, "Todos" %>

<div class="w-full">
  <h1 class="text-center font-bold text-4xl">Todos</h1>

  <div>
    <%= render "todos/form", todo: @todo %>
  </div>  

  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md text-center" id="notice"><%= notice %></p>
  <% end %>

  <div id="todos" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @todos.any? %>
      <% @todos.each do |todo| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render todo %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", todo, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= link_to "Edit", edit_todo_path(todo), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= button_to "Destroy", todo, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No todos found.</p>
    <% end %>
  </div>
</div>
