<% content_for :title, "Todos" %>

<div class="w-full">
  <h1 class="text-center text-4xl text-pink-600">Todos</h1>
  <div>
    <%= render "todos/form", todo: @todo %>
  </div>  

  <div class="flex justify-center mt-5">
    <div class="bg-linear-to-r bg-pink-300 to-blue-300 text-black w-120">
      <div id="todos" class="min-w-full space-y-5 mx-2">
        <% if @todos.any? %>
          <% @todos.each do |todo| %>
            <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
              <%= render todo %>
              <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
                <%= link_to "✏️", edit_todo_path(todo), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 inline-block font-medium" %>
                <%= button_to "X", todo, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-red-600 hover:text-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-center my-10">No todos found.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
