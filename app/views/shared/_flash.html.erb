<div
id="flash-container"
class="
fixed
top-6
left-1/2
-translate-x-1/2

z-999999

flex
flex-col
gap-3

w-full
max-w-sm

px-4
pointer-events-none
"
>


<% flash.each do |type, message| %>


<div
class="
flash-card

pointer-events-auto

relative
overflow-hidden

rounded-3xl

bg-zinc-950/90
backdrop-blur-2xl

border
border-white/10

shadow-[0_20px_60px_rgba(0,0,0,.5)]

p-4

flex
items-center
gap-3

opacity-0
-translate-y-8

transition-all
duration-300
"
>




<!-- ICON -->

<div
class="
h-11
w-11

shrink-0

rounded-2xl

flex
items-center
justify-center

text-lg

<%= type.to_s == "notice" ?
"bg-emerald-500/20 text-emerald-400" :
"bg-red-500/20 text-red-400"
%>
"
>


<%= type.to_s == "notice" ? "✓" : "!" %>


</div>






<!-- TEXT -->

<div class="flex-1">


<p class="
text-white
font-semibold
text-sm
">

<%= type.to_s.capitalize %>

</p>



<p class="
text-white/50
text-xs
mt-1
">

<%= message %>

</p>


</div>






<!-- CLOSE -->

<button

onclick="
this.closest('.flash-card').remove()
"

class="
h-7
w-7

rounded-xl

bg-white/5

text-white/50

hover:text-white
hover:bg-white/10

transition
"

>

×


</button>






<!-- TIMER -->

<div
class="
absolute
bottom-0
left-0

h-1

<%= type.to_s == "notice" ?
"bg-emerald-500" :
"bg-red-500"
%>

flash-progress
"
></div>




</div>


<% end %>


</div>






<script>


document.addEventListener(
"turbo:load",
()=>{


document
.querySelectorAll(".flash-card")
.forEach((card)=>{


setTimeout(()=>{


card.classList.remove(
"opacity-0",
"-translate-y-8"
)


card.classList.add(
"opacity-100",
"translate-y-0"
)


},50)





setTimeout(()=>{


card.classList.add(
"opacity-0",
"-translate-y-8"
)


setTimeout(
()=>card.remove(),
300
)


},3500)



})


})



</script>

<style>

.flash-progress{

animation:
flashTimer 3.5s linear forwards;

}


@keyframes flashTimer{

from{
width:100%;
}

to{
width:0%;
}

}

</style>
